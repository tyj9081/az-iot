<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aziot.dao.mapper.system.SysUserMapper">

    <!-- ════════════════════════════════════════════ -->
    <!-- 通用字段列表 (复用)                          -->
    <!-- ════════════════════════════════════════════ -->
    <sql id="Base_Column_List">
        id, username, password_hash, nickname, email, phone,
        avatar_url, status, is_deleted, last_login_time,
        created_at, updated_at
    </sql>

    <!-- ════════════════════════════════════════════ -->
    <!-- 简单查询: 按用户名查用户 (替换 AuthService 中的 LambdaQueryWrapper) -->
    <!-- ════════════════════════════════════════════ -->
    <select id="selectByUsername" resultType="com.aziot.dao.entity.system.SysUser">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_user
        WHERE username = #{username}
          AND is_deleted = 0
    </select>

    <!-- ════════════════════════════════════════════ -->
    <!-- 分页查询: 支持用户名/昵称 OR 模糊筛选        -->
    <!-- ════════════════════════════════════════════ -->
    <select id="selectPageByCondition" resultType="com.aziot.dao.entity.system.SysUser">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_user
        <where>
            is_deleted = 0
            <if test="keyword != null and keyword != ''">
                AND (username LIKE CONCAT('%', #{keyword}, '%')
                 OR nickname LIKE CONCAT('%', #{keyword}, '%'))
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

    <!-- ════════════════════════════════════════════ -->
    <!-- 批量查询: 按角色编码查用户                  -->
    <!-- ════════════════════════════════════════════ -->
    <select id="selectByRoleCode" resultType="com.aziot.dao.entity.system.SysUser">
        SELECT u.id, u.username, u.nickname, u.email, u.phone, u.status
        FROM sys_user u
        INNER JOIN sys_user_role ur ON u.id = ur.user_id
        INNER JOIN sys_role r ON ur.role_id = r.id
        WHERE r.role_code = #{roleCode}
          AND u.is_deleted = 0
          AND u.status = 1
    </select>

    <!-- ════════════════════════════════════════════ -->
    <!-- 统计查询                                    -->
    <!-- ════════════════════════════════════════════ -->
    <select id="countByStatus" resultType="int">
        SELECT COUNT(*) FROM sys_user WHERE status = #{status} AND is_deleted = 0
    </select>

</mapper>
