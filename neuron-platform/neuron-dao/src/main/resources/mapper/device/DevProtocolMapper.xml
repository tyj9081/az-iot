<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aziot.dao.mapper.device.DevProtocolMapper">

    <select id="selectAllEnabled" resultType="com.aziot.dao.entity.device.DevProtocol">
        SELECT * FROM dev_protocol
        WHERE is_enabled = 1
        ORDER BY id ASC
    </select>

</mapper>
