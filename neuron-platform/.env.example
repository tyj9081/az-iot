# ===== neuron-platform (Java Spring Boot) =====
# 复制此文件并根据环境修改，不要提交真实值到 Git

DB_URL=jdbc:mysql://your-host:3306/az_iot?useSSL=true&serverTimezone=Asia/Shanghai
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password
JWT_SECRET=<至少 256 bits 随机字符串，推荐生成方式: openssl rand -base64 64>
JWT_ACCESS_EXPIRATION=1800000
JWT_REFRESH_EXPIRATION=604800000
SERVER_PORT=8080

# ===== MQTT =====
MQTT_BROKER=tcp://your-broker:1883
MQTT_CLIENT_ID=neuron-platform
MQTT_USERNAME=your_mqtt_user
MQTT_PASSWORD=your_mqtt_password
